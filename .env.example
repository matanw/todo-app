# Copy this to .env and fill in your values
# .env is gitignored — never commit it

# ── GCP ──────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Auth ─────────────────────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Add OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Authorization ─────────────────────────────────────────────────
# Comma-separated emails allowed to use this app
ALLOWED_USERS=matanwis@gmail.com

# Set to true only for local dev/testing
ALLOW_ALL=false
ALLOW_DEVICE_AUTH=false
